# HTTP
HP_ADDR=:8080
HP_PUBLIC_BASE_URL=http://localhost:8080
HP_FRONTEND_BASE_URL=http://localhost:3000
HP_ALLOWED_ORIGINS=http://localhost:3000

# Database: driver is "sqlite" or "postgres"
HP_DB_DRIVER=sqlite
HP_DB_DSN=homeprojects.db
# Postgres example:
# HP_DB_DRIVER=postgres
# HP_DB_DSN=host=localhost user=hp password=hp dbname=homeprojects port=5432 sslmode=disable

# Sessions
HP_SESSION_SECRET=change-me-to-a-long-random-string
HP_SESSION_TTL=168h
HP_COOKIE_NAME=hp_session
HP_COOKIE_SECURE=false
# HP_COOKIE_DOMAIN=example.com

# SSO / OIDC (Pocket ID). Leave HP_OIDC_ISSUER empty to use dev-login locally.
HP_OIDC_ISSUER=
HP_OIDC_CLIENT_ID=
HP_OIDC_CLIENT_SECRET=
# Defaults to {HP_PUBLIC_BASE_URL}/api/auth/callback if unset:
# HP_OIDC_REDIRECT_URL=
HP_OIDC_SCOPES=openid,profile,email
